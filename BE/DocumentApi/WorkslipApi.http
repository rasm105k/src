Content-Type: application/json

{
  "fieldKey": "{{FieldKey}}",
  "label": "Ekstra note",
  "dataType": "Text",
  "isRequired": false,
  "sortOrder": 900,
  "options": null
}

###

PATCH {{DocumentApi_HostAddress}}/api/document-types/{{DocumentTypeId}}/fields/{{FieldKey}}
Content-Type: application/json

{
  "label": "Ekstra note til kontor",
  "dataType": "Text",
  "isRequired": false,
  "sortOrder": 905,
  "options": null
}

###

DELETE {{DocumentApi_HostAddress}}/api/document-types/{{DocumentTypeId}}/fields/{{FieldKey}}
Accept: application/json

###

GET {{DocumentApi_HostAddress}}/api/reports/{{ReportId}}/view-model
Accept: application/json

###

PATCH {{DocumentApi_HostAddress}}/api/workslips/{{ReportId}}
