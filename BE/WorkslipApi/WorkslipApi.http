###

GET {{WorkslipApi_HostAddress}}/api/workslips?limit=25&offset=0
Accept: application/json

###

GET {{WorkslipApi_HostAddress}}/api/workslips/{{ReportId}}
Accept: application/json

###

PATCH {{WorkslipApi_HostAddress}}/api/workslips/{{ReportId}}
Content-Type: application/json

{
  "remarks": "Opdateret fra backoffice",
  "closureFlags": ["faerdig", "klarTilFaktura"]
}

###

POST {{WorkslipApi_HostAddress}}/api/workslips/{{ReportId}}/submit
Accept: application/json

###

POST {{WorkslipApi_HostAddress}}/api/workslips/{{ReportId}}/approve
Accept: application/json

###

POST {{WorkslipApi_HostAddress}}/api/workslips/{{ReportId}}/reject
Accept: application/json
